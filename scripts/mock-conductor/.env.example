# Required — hostnames for FE and BE plugin instances
FRONTEND_HOST=localhost
BACKEND_HOST=localhost

# Plugin listen ports
FRONTEND_PORT=4001
BACKEND_PORT=4002

# Poll timing (seconds)
POLL_INTERVAL=1
TRANSFER_DELAY=0.5

# Local dev uses plain HTTP. Set true only for TLS/mTLS test environments.
USE_TLS=false

# TLS/mTLS settings — only used when USE_TLS=true
# Paths are relative to the directory you run the script from.
# CLIENT_CERT=testerdata/user.crt
# CLIENT_KEY=testerdata/user.key
# CA_CERT=
